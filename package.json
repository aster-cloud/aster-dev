{
  "name": "aster-dev",
  "version": "0.0.1",
  "private": true,
  "description": "aster-lang.dev 文档站（Next.js 重写，ADR 0018 Phase 3）。统一技术栈：与 aster-cloud 同 Next.js + next-intl + 运行时 ui-messages 加载。",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
