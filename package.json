    "remark-gfm": "^4.0.0",
    "rehype-slug": "^6.0.0",
    "@aster-cloud/tokens": "^0.2.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "shiki": "4.2.0",
    "next-themes": "^0.4.6",
    "lucide-react": "^1.18.0",
    "class-variance-authority": "^0.7.1",
